{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": ["artisan", "boost:mcp"]
        },
        "@21st-dev/magic": {
            "command": "npx",
            "args": ["-y", "@21st-dev/magic@latest", "API_KEY=\"your-magic-api-key-here\""]
        },
        "shadcn": {
            "command": "npx",
            "args": ["-y", "shadcn@latest", "mcp"]
        },
        "magicui": {
            "command": "npx",
            "args": ["-y", "@magicuidesign/mcp@latest"]
        },
        "context7": {
            "command": "npx",
            "args": ["-y", "@upstash/context7-mcp@latest"]
        }
    }
}
